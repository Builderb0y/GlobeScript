{
	"types": [
		"abstract class mc_tag extends object implements iterable",
		"class mc_holder extends object",
		"class block extends object",
		"class block_tag extends mc_tag",
		"class block_state extends object",
		"class biome extends mc_holder",
		"class biome_tag extends mc_tag",
		"class configured_feature extends mc_holder",
		"class configured_feature_tag extends mc_tag",
		"class entity_type extends mc_holder",
		"class entity_type_tag extends mc_tag",
		"class spawn_tweaker extends mc_holder",
		"class spawn_tweaker_tag extends mc_holder",
		"class world extends object implements column_lookup"
	],
	"environments": [
		{
			"name": "minecraft/base",
			"types": [
				"mc_tag Tag",
				"block Block",
				"block_tag BlockTag",
				"block_state BlockState",
				"biome Biome",
				"biome_tag BiomeTag",
				"configured_feature ConfiguredFeature",
				"configured_feature_tag ConfiguredFeatureTag",
				"entity_type EntityType",
				"entity_type_tag EntityTypeTag",
				"spawn_tweaker MobSpawnTweaker",
				"spawn_tweaker_tag MobSpawnTweakerTag",
			],
			"instance_fields": [
				"int mc_tag.size",
				"boolean mc_tag.isEmpty",
				"string block.id",
				"string mc_holder.id",
				"float biome.temperature",
				"float biome.downfall",
				{
					"owner": "block_state",
					"name": null,
					"type": "Comparable"
				}
			],
			"instance_methods": [
				"block_state block.getDefaultState()",
				"block_state block.getRandomState(random random)",
				"block_state block.getRandomState(long seed)",
				"block block_tag.random(random random)",
				"block block_tag.random(long seed)",
				"block block_state.getBlock()",
				"boolean block_state.isAir()",
				"boolean block_state.isReplaceable()",
				"boolean block_state.hasWater()",
				"boolean block_state.hasLava()",
				"boolean block_state.hasSoulLava()",
				"boolean block_state.hasFluid()",
				"boolean block_state.blocksLight()",
				"boolean block_state.hasCollision()",
				"boolean block_state.hasFullCubeCollision()",
				"boolean block_state.hasFullCubeOutline()",
				"block_state block_state.rotate(int angle)",
				"block_state block_state.mirror(string axis)",
				"block_state block_state.with(string property, Comparable value)",
				"biome biome_tag.random(random random)",
				"biome biome_tag.random(long seed)",
				"configured_feature configured_feature_tag.random(random random)",
				"configured_feature configured_feature_tag.random(long seed)",
				"entity_type entity_type_tag.random(random random)",
				"entity_type entity_type_tag.random(long seed)",
				"boolean block_state.isIn(block_tag tag)",
				"boolean block.isIn(block_tag tag)",
				"boolean biome.isIn(biome_tag tag)",
				"boolean configured_feature.isIn(configured_feature_tag tag)",
				"boolean entity_type.isIn(entity_type_tag tag)"
			],
			"keywords": [
				{ "name": "block_tag",             "keyword": "tag_constructor", "color": "type" },
				{ "name": "biome_tag",             "keyword": "tag_constructor", "color": "type" },
				{ "name": "configured_feature_tag", "keyword": "tag_constructor", "color": "type" },
				{ "name": "entity_type_tag",        "keyword": "tag_constructor", "color": "type" },
			],
			"casters": [
				"implicit string -> block",
				"implicit string -> block_state",
				"implicit string -> biome",
				"implicit string -> configured_feature",
				"implicit string -> entity_type",
			]
		},
		{
			"name": "minecraft/with_random",
			"includes": [
				"minecraft/base"
			],
			"instance_methods": [
				"block_state block.getRandomState()",
				"block block_tag.random()",
				"biome biome_tag.random()",
				"configured_feature configured_feature_tag.random()"
			]
		},
		{
			"name": "minecraft/with_world",
			"includes": [
				"minecraft/with_random"
			],
			"types": [
				"world World"
			],
			"instance_fields": [
				"long world.worldSeed",
				"int world.minValidYLevel",
				"int world.maxValidYLevel"
			],
			"instance_methods": [
				"block_state world.getBlockState(int*(x, y, z))",
				"boolean world.setBlockState(int*(x, y, z), block_state state)",
				"boolean world.setBlockStateReplaceable(int*(x, y, z), block_state state)",
				"boolean world.setBlockStateNonReplaceable(int*(x, y, z), block_state state)",
				"boolean world.updateBlockState(int*(x, y, z))",
				"boolean world.placeBlockState(int*(x, y, z), block_state state)",
				"void world.fillBlockState(int*(minX, minY, minZ, maxX, maxY, maxZ), block_state state)",
				"void world.fillBlockStateReplaceable(int*(minX, minY, minZ, maxX, maxY, maxZ), block_state state)",
				"void world.fillBlockStateNonReplaceable(int*(minX, minY, minZ, maxX, maxY, maxZ), block_state state)",
				"void world.updateBlockStates(int*(minX, minY, minZ, maxX, maxY, maxZ))",
				"boolean world.placeFeature(int*(x, y, z), configured_feature feature)",
				"boolean world.isYLevelValid(int y)",
				"boolean world.isPositionValid(int*(x, y, z))",
				//todo: getBlockData(), setBlockData(), mergeBlockData(), summon().
				"int world.transformX(int*(x, y, z))",
				"int world.transformY(int*(x, y, z))",
				"int world.transformZ(int*(x, y, z))",
				"double world.transformX(double*(x, y, z))",
				"double world.transformY(double*(x, y, z))",
				"double world.transformZ(double*(x, y, z))",

				"boolean block_state.canPlaceAt(int*(x, y, z))",
				"boolean block_state.canStayAt(int*(x, y, z))"
			]
		},
		{
			"name": "minecraft/with_imported_world",
			"includes": [
				"minecraft/with_world"
			],
			"imported_values": [
				"world  world"
			]
		}
	]
}
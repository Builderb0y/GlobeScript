{
	"environments": [
		{
			"name": "builtin",
			"types": [
				"boolean",
				"byte",
				"short",
				"char",
				"int",
				"long",
				"float",
				"double",
				"void",

				"Boolean",
				"Byte",
				"Short",
				"Character",
				"Integer",
				"Long",
				"Float",
				"Double",
				"Void",

				"Number",
				"object Object",
				"Comparable",
				"string String",
				"MinecraftVersion",
			],
			"variables": [
				{ "name": "true",  "type": "boolean", "color": "keyword", "constant": true },
				{ "name": "false", "type": "boolean", "color": "keyword", "constant": false },
				{ "name": "yes",   "type": "boolean", "color": "keyword", "constant": true },
				{ "name": "no",    "type": "boolean", "color": "keyword", "constant": false },
				{ "name": "null",  "type": { "name": "object", "generic": true }, "color": "keyword", "constant": null },
				{ "name": "noop",  "type": "void",    "color": "keyword", "statement": true }
			],
			"instance_fields": [
				"int MinecraftVersion.major",
				"int MinecraftVersion.minor",
				"int MinecraftVersion.bugfix"
			],
			"static_fields": [
				"MinecraftVersion MinecraftVersion.CURRENT"
			],
			"functions": [
				"meta(color = keyword, jumps = true) void return()",
				"meta(color = keyword, jumps = true) void return(value value)",
				"void print(value... values)",
				"int floorInt(int value)",
				"int floorInt(long value)",
				"int floorInt(float value)",
				"int floorInt(double value)",
				"int ceilInt(int value)",
				"int ceilInt(long value)",
				"int ceilInt(float value)",
				"int ceilInt(double value)",
				"int lowerInt(int value)",
				"int lowerInt(long value)",
				"int lowerInt(float value)",
				"int lowerInt(double value)",
				"int higherInt(int value)",
				"int higherInt(long value)",
				"int higherInt(float value)",
				"int higherInt(double value)",
				"int roundInt(int value)",
				"int roundInt(long value)",
				"int roundInt(float value)",
				"int roundInt(double value)",
				"int truncInt(int value)",
				"int truncInt(long value)",
				"int truncInt(float value)",
				"int truncInt(double value)",
				"long floorLong(int value)",
				"long floorLong(long value)",
				"long floorLong(float value)",
				"long floorLong(double value)",
				"long ceilLong(int value)",
				"long ceilLong(long value)",
				"long ceilLong(float value)",
				"long ceilLong(double value)",
				"long lowerLong(int value)",
				"long lowerLong(long value)",
				"long lowerLong(float value)",
				"long lowerLong(double value)",
				"long higherLong(int value)",
				"long higherLong(long value)",
				"long higherLong(float value)",
				"long higherLong(double value)",
				"long roundLong(int value)",
				"long roundLong(long value)",
				"long roundLong(float value)",
				"long roundLong(double value)",
				"long truncLong(int value)",
				"long truncLong(long value)",
				"long truncLong(float value)",
				"long truncLong(double value)",
			],
			"keywords": [
				{ "name": "var",      "keyword": "var"       },
				{ "name": "class",    "keyword": "class"     },
				{ "name": "if",       "keyword": "body_if"   },
				{ "name": "unless",   "keyword": "body_if"   },
				{ "name": "while",    "keyword": "while"     },
				{ "name": "until",    "keyword": "while"     },
				{ "name": "do",       "keyword": "do"        },
				{ "name": "repeat",   "keyword": "repeat"    },
				{ "name": "for",      "keyword": "for"       },
				{ "name": "switch",   "keyword": "switch"    },
				{ "name": "block",    "keyword": "block"     },
				{ "name": "break",    "keyword": "loop_jump" },
				{ "name": "continue", "keyword": "loop_jump" },
				//{ "name": "compare",  "keyword": "compare"   },
				{ "name": "noscope",  "keyword": "noscope"  }
			],
			"instance_keywords": [
				{ "name": "if",        "owner": "boolean",          "keyword": "receiver_if" },
				{ "name": "unless",    "owner": "boolean",          "keyword": "receiver_if" },
				{ "name": "is",        "owner": "object",           "keyword": "is" },
				{ "name": "isnt",      "owner": "object",           "keyword": "is" },
				{ "name": "as",        "owner": "value",            "keyword": "as" },
				{ "name": "isBetween", "owner": "primitive_number", "keyword": "between", "color": "instance_method" }
			],

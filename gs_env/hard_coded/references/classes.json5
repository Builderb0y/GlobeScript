{
	"references": [

		//normal classes

		{
			"file_path": "/data/[a-z_.\\-]+/bigglobe/custom_class/",
			"json_path": "extends",
			"registry": "bigglobe/custom_class",
			"when": {
				"element_type": [
					"class/normal",
					"bigglobe:class/normal"
				]
			},
			"filter": {
				"element_type": [
					"class/normal",
					"bigglobe:class/normal"
				]
			},
			"reference_type": "element"
		},

		//enum classes

		{
			"file_path": "/data/[a-z_.\\-]+/bigglobe/custom_class/",
			"json_path": "extends",
			"registry": "bigglobe/custom_class",
			"when": {
				"element_type": [
					"class/enum",
					"bigglobe:class/enum"
				]
			},
			"filter": {
				"element_type": [
					"class/enum",
					"bigglobe:class/enum"
				]
			},
			"reference_type": "element"
		}
	]
}
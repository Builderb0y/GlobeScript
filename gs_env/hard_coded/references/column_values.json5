{
	"references": [
		{
			"file_path": "/data/[a-z_.\\-]+/bigglobe/worldgen/column_value/",
			"json_path": "params>type",
			"registry": "bigglobe/custom_class",
			"default_namespace": "bigglobe",
			"reference_type": "element",
			"when": {},
			"filter": {
				"element_type": [
					"class/builtin",
					"class/normal",
					"class/enum",
					"bigglobe:class/builtin",
					"bigglobe:class/normal",
					"bigglobe:class/enum"
				]
			}
		},
		{
			"file_path": "/data/[a-z_.\\-]+/bigglobe/worldgen/column_value/",
			"json_path": "root",
			"registry": "bigglobe/worldgen/decision_tree",
			"default_namespace": "bigglobe",
			"reference_type": "element",
			"when": {
				"type": [
					"decision_tree",
					"bigglobe:decision_tree"
				]
			}
		}
	]
}
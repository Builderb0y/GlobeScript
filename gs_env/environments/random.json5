{
	"types": [
		"interface Random"
	],
	"environments": [
		{
			"name": "random/instance",
			"includes": [
				"random/base"
			],
			"variables": [
				"Random random"
			]
		},
		{
			"name": "random/base",
			"types": [
				{ "name": "Random", "type": "Random" }
			],
			"static_methods": [
				{
					"owner": "Random",
					"name": "new",
					"type": "Random",
					"color": "keyword",
					"parameters": [
						{ "name": "seed", "type": "long" },
						{ "name": "salt", "type": "int", "repeatable": true }
					]
				}
			],
			"instance_methods": [
				"int Random.nextInt()",
				"int Random.nextInt(int max)",
				"int Random.nextInt(int*(min, max))",
				"long Random.nextLong()",
				"long Random.nextLong(long min)",
				"long Random.nextLong(long*(min, max))",
				"float Random.nextFloat()",
				"float Random.nextFloat(float min)",
				"float Random.nextFloat(float*(min, max))",
				"double Random.nextDouble()",
				"double Random.nextDouble(double max)",
				"double Random.nextDouble(double*(min, max))",
				"boolean Random.nextBoolean()",
				"boolean Random.nextBoolean(float chance)",
				"boolean Random.nextBoolean(double chance)",
				"double Random.nextGaussian()",
				"double Random.nextGaussian(double*(mean, standardDeviation))",
				"double Random.nextExponential()",
				"int Random.roundInt(float number)",
				"int Random.roundInt(double number)",
				"long Random.roundLong(float number)",
				"long Random.roundLong(double number)"
			],
			"instance_keywords": [
				{ "owner": "Random", "name": "if",     "keyword": "random_if"     },
				{ "owner": "Random", "name": "unless", "keyword": "random_if"     },
				//{ "owner": "Random", "name": "switch", "keyword": "random_switch" }
			]
		}
	]
}